# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL + PostGIS
# 5433 : port exposé par docker-compose.yml ('5433:5432'), choisi pour ne pas
# entrer en conflit avec un PostgreSQL déjà installé sur la machine.
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=livrechap

# Redis (cache positions livreurs, files de matching)
REDIS_URL=redis://localhost:6379

# Cartographie
MAPBOX_ACCESS_TOKEN=

# Geocoding serveur (GET /geocoding/reverse) — repli du sélecteur d'adresse mobile.
# Chaîne : Mapbox (MAPBOX_ACCESS_TOKEN ci-dessus) → OSM/Nominatim.
# Le mobile n'appelle jamais Nominatim en direct : le backend porte le repli,
# son cache et son rate-limiting.
NOMINATIM_ENABLED=true
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# User-Agent identifiable, exigé par la politique d'usage de l'instance publique.
NOMINATIM_USER_AGENT=Livrechap/1.0 (contact@livrechap.ci)
# Cache Redis des adresses résolues (clé arrondie à 4 décimales ≈ 10-15 m).
GEOCODING_CACHE_TTL_SECONDS=2592000
# Plafond par utilisateur et par minute.
GEOCODING_RATE_LIMIT_PER_MINUTE=60

# Notifications push
# Mode : "console" (dev, journalise les push) ou "live" (Firebase Cloud Messaging)
FCM_MODE=console
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Authentification — JWT
# Générer des secrets forts et distincts en production (ex: `openssl rand -base64 48`)
JWT_ACCESS_SECRET=dev_access_secret_a_changer_en_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_refresh_secret_a_changer_en_production
JWT_REFRESH_EXPIRES_IN=30d

# OTP téléphone
SMS_PROVIDER_API_KEY=
# Fournisseur SMS : "console" (dev, affiche l'OTP dans les logs) ou "twilio"
SMS_PROVIDER=console
# Expéditeur affiché sur le SMS
SMS_SENDER=Livrechap
# Paramètres OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5
# Poivre appliqué au hachage des codes OTP stockés dans Redis (changer en production)
OTP_PEPPER=dev_otp_pepper_a_changer_en_production
# Code OTP fixe pour faciliter les tests en dev — accepté pour tout numéro.
# Laisser VIDE en production (de toute façon ignoré si NODE_ENV=production).
OTP_DEV_BYPASS_CODE=

# Paiement / recharge du Crédit Livrechap
# Mode : "sandbox" (dev, recharge confirmée immédiatement) ou "live" (API réelle)
PAYMENTS_MODE=sandbox
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
WAVE_API_KEY=

# Stockage fichiers (selfies, CNI, photos de colis)
# Mode : "local" (dev, écrit sur disque et sert via /uploads) ou "s3" (R2/S3)
STORAGE_MODE=local
STORAGE_LOCAL_DIR=uploads
# URL publique du backend, utilisée pour construire les URLs des fichiers locaux
PUBLIC_BASE_URL=http://localhost:3000
STORAGE_PROVIDER=cloudflare_r2
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=livrechap-uploads

# Paramètres métier
WALLET_MINIMUM_RECHARGE_FCFA=1000
WALLET_WELCOME_BONUS_FCFA=500
COMMISSION_RATE_PERCENT=10
COMMISSION_MINIMUM_FCFA=200
MATCHING_INITIAL_RADIUS_KM=2
MATCHING_RADIUS_STEPS_KM=5,10

# Lien de suivi envoye par SMS au destinataire s il a un compte Livrechap.
# Vide = aucun lien dans le SMS (seul le code part).
APP_DEEP_LINK_BASE=livrechap://
