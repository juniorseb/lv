# API Livrechap. Sur un vrai téléphone (Expo Go), « localhost » désigne le
# téléphone : mettre l'IP LAN du PC (ex. http://192.168.1.10:3000).
EXPO_PUBLIC_API_URL=http://localhost:3000

# Token public Mapbox (pk.*) — cartes, autocomplétion, itinéraires.
EXPO_PUBLIC_MAPBOX_TOKEN=

# OPTIONNEL — Yandex Geocoder, fournisseur alternatif de l'AddressSearchService
# (spec-address-picker-map-v3 §9). Sans clé, le connecteur reste inactif et la
# chaîne se limite à Mapbox puis au backend Livrechap (qui porte le repli
# OSM/Nominatim). Clé à obtenir dans la console développeur Yandex, service
# « Geocoder API ». Pour le placer en tête de chaîne : réordonner les tableaux
# de src/services/addressSearch.ts.
EXPO_PUBLIC_YANDEX_API_KEY=
